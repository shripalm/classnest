# Application
PROJECT_NAME=ClassNest API
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=80
STAGE_PATH=

# Database
DB_URL=postgresql+asyncpg://postgres:nopass@db:5432/classnest

# Database Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=60
DB_POOL_RECYCLE=3600

# Security
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Logging Settings
LOG_LVL=DEBUG

# SMTP Settings
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_EMAIL="your-email@gmail.com"
SMTP_FROM_NAME="ClassNest System"

# SendGrid Settings
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@classnest.com"
SENDGRID_FROM_NAME="ClassNest"

# OTP Settings
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6
